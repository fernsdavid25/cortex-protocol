# Cortex Protocol — environment template.
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Self-hosters: BRING YOUR OWN KEY — nothing phones home; your keys/DB stay on your machine.

# --- LLM provider (Gemini; provider-abstracted for Claude/OpenAI/OpenRouter/Ollama later) ---
# BYOK: get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=                        # local MCP server key (falls back to GOOGLE_API_KEY)
GOOGLE_API_KEY=                        # accepted as an alias for GEMINI_API_KEY

# --- Local memory MCP server (uvx cortex-mcp) ---
CORTEX_DB_PATH=~/.cortex/memory.db     # local SQLite memory file (no Docker, no DB server)
CORTEX_USER_ID=local                   # namespace within the DB
CORTEX_EMBED_MODEL=gemini-embedding-001
CORTEX_EMBED_DIM=768
CORTEX_TOP_K=5                          # default number of memories recall() returns

# --- Benchmark harness: per-role model selection (harness reads these; CLI flags override) ---
# A LongMemEval run uses 4 model ROLES (see bench/results/PHASE3_authoritative.md):
#   reader  = answers from the retrieved memories  -> accuracy lever + main per-query cost
#   embed   = vectorizes memories + the query for retrieval -> one-time at ingest
#   extract = OPTIONAL cheap model for fact-keys / reflection prep
#   judge   = grades the reader's answer vs gold  -> EVAL ONLY, never ships (see judge block below)
CORTEX_READER_MODEL=gemini-3.5-flash          # best accuracy-per-dollar (~$0.008/q on _S 500)
CORTEX_EXTRACT_MODEL=gemini-2.5-flash-lite    # cheap extractor/reflection model

# --- Benchmark JUDGE (eval only — grades reader vs gold; never part of the product) ---
# Default judge = gemini-3.5-flash. To use the canonical GPT-4o judge, set the openai backend +
# key. Tip: pick a judge model DIFFERENT from CORTEX_READER_MODEL to avoid self-preference bias.
CORTEX_JUDGE_BACKEND=gemini            # gemini | openai | offline
CORTEX_JUDGE_MODEL=gemini-3.5-flash    # or gpt-4o-2024-08-06 (with backend=openai)
CORTEX_JUDGE_VOTES=3                   # self-consistency votes for the gemini judge
OPENAI_API_KEY=                        # only needed for the openai (gpt-4o) judge backend
